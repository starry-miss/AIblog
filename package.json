{
  "name": "aiblog",
  "version": "1.0.0",
  "description": "AI-Powered Personal Blog System",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "init-db": "node server/init-db.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mysql2": "^3.6.5",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "openai": "^4.20.0",
    "marked": "^11.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2"
  }
}
